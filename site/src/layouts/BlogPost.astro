---
import { SITE_TITLE, SITE_AUTHOR } from "../consts";
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

import BaseHead from '../components/BaseHead.astro';
import FormattedDate from "../components/FormattedDate.astro";
import Navigation from "../components/Navigation.astro";
import Social from "../components/Social.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import BlogSidebar from "../components/BlogSidebar.astro";
import { getSeriesPosts, getRelatedPosts } from "../utils/relatedContent";

const today = new Date();
const { title, description, pubDate, updatedDate, series, heroImage, canonical, post } = Astro.props.frontmatter || Astro.props;

// Get all blog posts for series/related content
const allBlogPosts = await getCollection('blog');
const currentPost = post as CollectionEntry<'blog'>;

// Determine what to show in sidebar
let seriesPosts: CollectionEntry<'blog'>[] = [];
let relatedPosts: CollectionEntry<'blog'>[] = [];

console.log('=== BlogPost Debug ===');

// Safety check for papers or other content that doesn't have a slug
if (!currentPost || !currentPost.slug) {
    console.log('No currentPost or slug, skipping related content');
} else {
    console.log('currentPost.slug:', currentPost.slug);
    console.log('series:', series);
    console.log('allBlogPosts.length:', allBlogPosts.length);

    if (series) {
        seriesPosts = getSeriesPosts(allBlogPosts, currentPost);
        console.log('Found', seriesPosts.length, 'posts in series');
    } else {
        relatedPosts = getRelatedPosts(allBlogPosts, currentPost, 5);
        console.log('Found', relatedPosts.length, 'related posts');
    }
}
---

<!DOCTYPE html>
<html lang="en" data-theme="light" transition:animate="none">
<head>
	<BaseHead title={`${title} | ${SITE_TITLE}`} description={description} image={heroImage} canonical={canonical} />
	<script is:inline>
		// Prevent theme flicker during View Transitions
		document.addEventListener('astro:before-swap', (ev) => {
			const theme = localStorage.getItem('theme') || 'light';
			ev.newDocument.documentElement.setAttribute('data-theme', theme);
		});
	</script>
	<style>
		main {
			width: 100%;
			max-width: 1200px;
			margin: 0 auto;
			padding: 0 1em;
		}

		.content-wrapper {
			display: grid;
			grid-template-columns: 1fr;
			gap: 2rem;
			margin-top: 2rem;
		}

		@media (min-width: 1024px) {
			.content-wrapper {
				grid-template-columns: 1fr 320px;
			}
		}

		div.prose {
			width: 100%;
			max-width: 800px;
			color: var(--color-text);
		}

		.hero-image {
			margin-top: 30px;
			width: 100%;
		}

		.hero-image img {
			display: block;
			margin: 0 auto;
			border-radius: 12px;
			box-shadow: var(--box-shadow);
		}

		.title {
			margin: 2em 0 1em;
			padding: 1em 0;
			text-align: center;
			line-height: 1;
		}

		.title h1 {
			margin: 0 0 0.5em 0;
		}

		.date {
			margin-bottom: 0.5em;
			color: var(--color-text);
		}

		.last-updated-on {
			font-style: italic;
		}

		footer {
			padding: 2em 1em 6em 1em;
			color: var(--color-text);
			text-align: center;
		}

		.light-dark {
			position: fixed;
			top: 0;
			left: 0;
			padding: 10px;
		}
	</style>
</head>

<body>
	<div class="light-dark">
		<ThemeToggle/>
	</div>

	<main>
		<Social/>
		<Navigation/>

		<div class="hero-image">
			{heroImage && <img width={1020} height={510} src={heroImage} alt="" />}
		</div>

		<div class="title">
			<h1>{title}</h1>
			{
				series && (
					<h3>{`${series.title} - ${series.subtitle}`}</h3>
				)
			}
			<div class="date">
				<FormattedDate date={pubDate} />
				{
					updatedDate && (
						<div class="last-updated-on">
							Last updated on <FormattedDate date={updatedDate} />
						</div>
					)
				}
			</div>
			<br/>
			<hr />
		</div>

		<div class="content-wrapper">
			<div class="prose">
				<article>
					<slot/>
				</article>
			</div>
			<BlogSidebar 
				seriesPosts={seriesPosts}
				relatedPosts={relatedPosts}
				currentSlug={currentPost?.slug || ''}
			/>
		</div>
	</main>

	<footer>
		<p>&copy; {today.getFullYear()}&nbsp;{SITE_AUTHOR}. All rights reserved.</p>
		<Social/>
	</footer>
</body>
</html>
